# Copy to .env and fill in. .env is NEVER committed.

# --- OpenClaw (the brain) ---
# Local gateway by default; change if your OpenClaw runs elsewhere.
OPENCLAW_URL=http://127.0.0.1:18789
# Gateway token (gateway.auth.token / OPENCLAW_GATEWAY_TOKEN in your OpenClaw)
OPENCLAW_TOKEN=

# --- OpenAI (speech-to-text + the fast persona layer) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ElevenLabs (voice) ---
ELEVENLABS_API_KEY=
# Default voice_id (per-agent voice is set in agents.local.json). Pick a pt-BR voice.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Flash v2.5 = best for LIVE conversation (low latency + timestamps for lip-sync).
# Don't use eleven_v3 here (slower); use v3 only for pre-generated phrases.
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Voice fine-tuning (0..1, except speed). Lower stability = more expressive/human.
ELEVENLABS_STABILITY=0.4
ELEVENLABS_SIMILARITY=0.8
ELEVENLABS_STYLE=0.35
ELEVENLABS_SPEAKER_BOOST=true
ELEVENLABS_SPEED=1.0

# --- Security ---
# If set, every /api/* call must carry this secret (?k=... or x-incarna-token header).
# Use it to lock a public tunnel: share the link as https://.../?k=YOUR_SECRET
SESSION_TOKEN=
# Rate limit (token bucket per IP) for the expensive endpoints (agent/tts/stt).
RATE_LIMIT_CAPACITY=40
RATE_LIMIT_REFILL_MS=1500

# Allow the Action Lab to write actions.json from the browser (dev only). Keep false in prod.
ALLOW_DEV_WRITES=false

# PORT=8080
